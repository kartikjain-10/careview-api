# Copy to .env and fill in your values. Never commit .env to git.

# AI
GROQ_API_KEY=your_groq_api_key_here

# Storage
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/careview.db

# Firebase (leave blank to run in demo-auth mode locally)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# App
APP_BASE_URL=http://localhost:3000

# Demo auth — set true for local dev only, NEVER in production
ALLOW_DEMO_AUTH=false

# Super-admin email (auto-promoted on first login)
ADMIN_SEED_EMAIL=
