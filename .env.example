# CareView environment variables — copy to .env and fill in values

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# SQLite
SQLITE_DB_PATH=./data/careview.db

# Firebase Auth
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# WhatsApp (no API key needed — uses deep links only, no WhatsApp Business API)
# Phone numbers must include country code: +91XXXXXXXXXX for India
